# Drizzle
# Replace with your DB credentials!
DATABASE_URL="postgres://user:password@host:port/db-name"

# Neon Auth
# From the Neon Console (Project -> Branch -> Auth). Both point at the same
# hosted Auth URL; PUBLIC_ is exposed to the browser, the other is server-only.
PUBLIC_NEON_AUTH_URL=""
NEON_AUTH_URL=""
