# Template for .env.test — the e2e test database config.
#
# Do NOT fill this in by hand. Run `bun run db:test:setup` and it will create
# the dedicated Neon `test` branch and generate a real .env.test for you.
# (.env.test itself is gitignored; this .example is committed as documentation.)

# Pooled connection string for the Neon `test` branch.
DATABASE_URL="postgresql://user:password@ep-xxxx-pooler.region.aws.neon.tech/neondb?sslmode=require"

# Guard flag. scripts/reset-test-db.ts and playwright.config.ts both refuse to
# run unless this is exactly "1" — it is what distinguishes the test branch
# from production and prevents destructive tests touching the real database.
TEST_DB=1
